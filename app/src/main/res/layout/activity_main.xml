<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔦 Flashlight"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Управление кнопкой громкости"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- BATTERY CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="АККУМУЛЯТОР"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/batPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—%"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <ProgressBar
                        android:id="@+id/batBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="100"
                        android:progressTint="@color/green"
                        android:progressBackgroundTint="@color/card_inner"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/batStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Определение..."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- SERVICE STATUS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="СТАТУС СЕРВИСА"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/statusIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="?"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/statusTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Проверка..."
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp"/>

                    <TextView
                        android:id="@+id/statusDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/enableBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Включить сервис"
                android:textColor="@color/bg_dark"
                android:backgroundTint="@color/yellow"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- GESTURE HINT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЖЕСТ"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3 × кнопка громкости"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔦 включить"
                    android:textColor="@color/yellow"
                    android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4 × кнопка громкости"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="выключить"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- AUTO-OFF SETTINGS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="АВТОВЫКЛЮЧЕНИЕ"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <!-- Toggle row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Таймер автовыключения"
                        android:textColor="@color/white"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="По умолчанию 1 минута"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/autoSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/yellow"
                    android:trackTint="@color/switch_track"/>
            </LinearLayout>

            <!-- Timer controls -->
            <LinearLayout
                android:id="@+id/timerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">

                <!-- Slider row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1м"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginEnd="8dp"/>

                    <SeekBar
                        android:id="@+id/timerSlider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="19"
                        android:progress="0"
                        android:progressTint="@color/yellow"
                        android:thumbTint="@color/yellow"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20м"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/timerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 мин"
                        android:textColor="@color/yellow"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:minWidth="52dp"
                        android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Presets -->
                <RadioGroup
                    android:id="@+id/presetGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton android:id="@+id/preset1"  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1м"  android:textColor="@color/text_secondary" android:buttonTint="@color/yellow" android:checked="true"/>
                    <RadioButton android:id="@+id/preset3"  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="3м"  android:textColor="@color/text_secondary" android:buttonTint="@color/yellow"/>
                    <RadioButton android:id="@+id/preset5"  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="5м"  android:textColor="@color/text_secondary" android:buttonTint="@color/yellow"/>
                    <RadioButton android:id="@+id/preset10" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="10м" android:textColor="@color/text_secondary" android:buttonTint="@color/yellow"/>
                    <RadioButton android:id="@+id/preset20" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="20м" android:textColor="@color/text_secondary" android:buttonTint="@color/yellow"/>
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>

        <!-- WORKS ON LOCK SCREEN NOTE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✓ Работает на заблокированном экране\n✓ Уведомление в шторке с таймером\n✓ Кнопка выключения в уведомлении"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
